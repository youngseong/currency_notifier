{
  // Exchange rate source
  // api_key: name of the environment variable that holds the actual API key
  "currency": {
    "api": "geoapi",
    "api_key": "GEO_API_KEY",
    "base": "KRW",
    "amount": 1000000,
    // Per-target thresholds: notify when the converted amount meets the condition
    "targets": {
      "EUR": { "threshold": 730,    "comparator": "gt" },
      "JPY": { "threshold": 100000, "comparator": "gt" },
      "USD": { "threshold": 740,    "comparator": "gt" }
    }
  },

  // Where to send the notification
  // token: name of the environment variable that holds the Telegram bot token
  "notification": {
    "token": "TELEGRAM_BOT_TOKEN",
    "chat_ids": [6144059945, 6023918749]
  }
}
